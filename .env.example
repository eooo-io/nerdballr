###############################################################################
# FFIS — Environment Example
# Copy to .env and fill in secrets. Never commit .env with real values.
###############################################################################

# ─── Laravel ──────────────────────────────────────────────────
APP_NAME=FFIS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_ROOT_PASSWORD=password
DB_DATABASE=ffis
DB_USERNAME=ffis
DB_PASSWORD=password

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── Cache / Queue / Session ─────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── MinIO (S3-compatible storage) ───────────────────────────
FILESYSTEM_DISK=minio
MINIO_ROOT_USER=ffis_minio
MINIO_ROOT_PASSWORD=ffis_minio_secret
MINIO_BUCKET=ffis-media
AWS_ACCESS_KEY_ID=ffis_minio
AWS_SECRET_ACCESS_KEY=ffis_minio_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=ffis-media
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/ffis-media
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025

# ─── Sanctum ──────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost

# ─── Anthropic AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
